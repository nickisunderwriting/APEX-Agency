  .bc-col-label.bc-neg{color:var(--red);}
  .bc-list{margin:0; padding-left:18px; font-size:13.5px; line-height:1.6; color:var(--text);}
  .bc-list li{margin-bottom:3px;}
  .bc-videolink{display:inline-block; background:var(--ink); color:#fff; padding:11px 16px; border-radius:12px; font-size:13.5px; font-weight:600; text-decoration:none;}
  .bc-videolink:hover{background:var(--ink-soft);}
  .bc-providers{display:flex; flex-wrap:wrap; gap:8px; margin-top:4px;}
  .bc-provider{background:var(--blue-soft); color:var(--blue-deep); border:1px solid #D5E3FB; border-radius:20px; padding:8px 14px; font-size:13px; font-weight:600; text-decoration:none;}
  .bc-provider:hover{filter:brightness(.98);}
  .bc-table{width:100%; border-collapse:collapse; font-size:13.5px;}
  .bc-table td{padding:6px 8px; border-bottom:1px solid var(--line); color:var(--text);}
  .bc-table .bc-lvl{font-weight:700; color:var(--blue); width:64px;}
</style>
