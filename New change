    const resetBtn = document.getElementById('resetBtn');
    if(resetBtn) resetBtn.onclick = async ()=>{
      if(confirm('Reset all of your checked steps and notes? This cannot be undone.')){
        progress = { name: progress.name, completed:{}, notes:{} };
        await saveJSON('progress', progress, false);
        render();
      }
    };
  }

  // ---------------- Init ----------------
  // Smoothly dismiss the branded loading screen and fade the app in.
  function dismissLoader(){
    const loader = document.getElementById('apexLoader');
    const appEl = document.getElementById('app');
    if(appEl) appEl.classList.add('ready');
    if(loader){
      loader.classList.add('fade-out');
      // remove from layout after the fade completes
      setTimeout(()=>{ loader.classList.add('hidden'); }, 600);
    }
  }

  async function init(){
    const startedAt = Date.now();
    const [loadedOrg, loadedProgress, loadedScores, loadedDaily] = await Promise.all([
      loadJSON('org-info', true, orgInfo),
      loadJSON('progress', false, progress),
      loadJSON('quiz-scores', false, {}),
      loadJSON('daily-checks', false, {date:'', checks:{}}),
    ]);
    orgInfo = loadedOrg;
    progress = Object.assign({ name:'', completed:{}, notes:{} }, loadedProgress);
    quizScores = loadedScores || {};
    // Daily checklist resets automatically on a new calendar day.
    const today = new Date().toDateString();
    if(loadedDaily && loadedDaily.date === today){
      dailyChecks = loadedDaily.checks || {};
    } else {
      dailyChecks = {};
    }
    render();
    // Always show the branded loader for a brief, smooth beat (min ~900ms total).
    const elapsed = Date.now() - startedAt;
    const minShow = 900;
    setTimeout(dismissLoader, Math.max(0, minShow - elapsed));
  }

  async function saveDaily(){
    try{ await saveJSON('daily-checks', {date:new Date().toDateString(), checks:dailyChecks}, false); }
    catch(e){ console.error('daily save failed', e); }
  }

  init();
})();
</script>
</body>
</html>
