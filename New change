<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>APEX Agency — Field Manual</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400..900&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    /* Light theme surfaces */
    --bg:#F7F9FC;            /* page background */
    --surface:#FFFFFF;       /* cards */
    --surface-2:#F1F4F9;     /* subtle raised/inset areas */
    --line:#E4E9F1;          /* hairline borders */
    --line-soft:#EEF1F7;
    --text:#0F1726;          /* primary text */
    --text-soft:#5A6B82;     /* secondary text */
    --text-faint:#8A98AC;    /* tertiary / hints */

    /* Brand accents */
    --blue:#2F6FE3;
    --blue-deep:#1E4FB8;
    --blue-soft:#EAF1FE;
    --gold:#C8972F;
    --gold-deep:#A87C1E;
    --ink:#0E1726;           /* dark accent (buttons, logo bar) */
    --ink-soft:#1B2740;      /* dark accent hover */

    --green:#2E7D52;
    --green-soft:#E6F2EB;
    --red:#C0392B;

    /* Legacy aliases so existing rules keep working on light theme */
    --paper:var(--surface);
    --paper-dim:var(--line);
    --text-on-paper:var(--text);
    --text-soft-on-paper:var(--text-soft);
    --brass:var(--blue);
    --brass-deep:var(--blue-deep);
    --forest:var(--green);
    --forest-soft:var(--green-soft);
    --rust:var(--red);
    --slate:var(--text-soft);
    --slate-dim:var(--text-faint);
    --ink-line:var(--line);
  }
  html{scroll-behavior:smooth;}
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    background:var(--bg);
    color:var(--text);
    font-family:'Inter',sans-serif;
    -webkit-font-smoothing:antialiased;
  }
  @media (prefers-reduced-motion: reduce){
    *{animation-duration:0.001ms !important; transition-duration:0.001ms !important;}
  }
  a{color:var(--blue);}
  .detail-text a, .how-list a, .script-stage-lines a, .bc-text a{color:var(--blue); font-weight:600; text-decoration:underline;}
  button{font-family:inherit;}
  :focus-visible{outline:2px solid var(--brass); outline-offset:3px; border-radius:6px;}

  .wrap{max-width:1180px; margin:0 auto; padding:0 24px 80px;}

  .brandbar{display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:14px; padding:24px 0 0;}
  .brandmark{display:flex; align-items:center; justify-content:center; gap:10px; background:var(--ink); padding:10px 22px; border-radius:16px; box-shadow:0 6px 18px -10px rgba(14,23,38,0.5);}
  .brand-logo-img{height:48px; width:auto; display:block;}
  .mode-toggle{display:flex; gap:4px; background:var(--surface); border:1px solid var(--line); border-radius:14px; padding:4px; box-shadow:0 1px 2px rgba(16,24,42,0.04);}
  .mode-btn{
    background:transparent; border:none; color:var(--text-soft); font-size:13px; font-weight:500;
    padding:8px 16px; border-radius:11px; cursor:pointer; font-family:inherit; transition:background .15s ease, color .15s ease;
  }
  .mode-btn.active{background:var(--blue); color:#fff; font-weight:600;}

  /* ---------- Header ---------- */
  header.top{
    padding:34px 0 26px;
  }
  .eyebrow{
    font-size:13px;
    font-weight:600;
    color:var(--blue);
    display:flex; align-items:center; gap:10px; flex-wrap:wrap;
  }
  .eyebrow .dot{width:4px;height:4px;border-radius:50%;background:var(--text-faint);}
  h1.title{
    font-family:'Fraunces', serif;
    font-weight:600;
    font-size:clamp(33px, 4.8vw, 52px);
    line-height:1.06;
    margin:10px 0 10px;
    letter-spacing:-0.015em;
    color:var(--text);
  }
  .subtitle{color:var(--text-soft); font-size:15.5px; max-width:560px; line-height:1.6;}

  .head-row{display:flex; justify-content:space-between; align-items:flex-end; gap:24px; flex-wrap:wrap;}

  .mentor-card{
    background:var(--surface);
    border:1px solid var(--line);
    border-radius:18px;
    padding:18px 20px;
    min-width:260px;
    position:relative;
    box-shadow:0 1px 2px rgba(16,24,42,0.04), 0 12px 28px -22px rgba(16,24,42,0.25);
  }
  .mentor-card .label{font-size:12px; font-weight:600; color:var(--text-faint); margin-bottom:7px;}
  .mentor-card .name{font-weight:600; font-size:15px;}
  .mentor-card .meta{color:var(--text-soft); font-size:13px; margin-top:3px;}
  .mentor-card .placeholder{color:var(--text-faint); font-size:13px; font-style:italic;}
  .edit-pencil{
    position:absolute; top:12px; right:12px;
    background:none; border:none; color:var(--text-faint); cursor:pointer;
    font-size:13px; padding:4px; border-radius:6px;
  }
  .edit-pencil:hover{color:var(--blue);}

  .edit-panel{
    margin-top:12px; padding-top:12px; border-top:1px solid var(--line);
    display:grid; gap:9px;
  }
  .edit-panel input{
    background:var(--surface-2); border:1px solid var(--line); color:var(--text);
    padding:9px 11px; border-radius:10px; font-size:13px; font-family:inherit; width:100%;
  }
  .edit-panel input:focus{border-color:var(--blue); outline:none; background:#fff;}
  .edit-panel .row-label{font-size:11.5px; color:var(--text-faint); margin-bottom:3px; display:block;}
  .edit-panel .note{font-size:11.5px; color:var(--text-faint); line-height:1.45;}
  .save-btn{
    background:var(--blue); color:#fff; border:none; border-radius:10px;
    padding:9px 15px; font-size:13px; font-weight:600; cursor:pointer; margin-top:4px; transition:background .15s ease;
  }
  .save-btn:hover{background:var(--blue-deep);}
  .save-btn:disabled{background:var(--line); color:var(--text-faint); cursor:not-allowed;}

  /* ---------- Name banner ---------- */
  .name-banner{
    margin-top:18px; background:var(--blue-soft); border:1px solid #D5E3FB;
    border-radius:14px; padding:14px 18px; display:flex; gap:10px; align-items:center; flex-wrap:wrap;
  }
  .name-banner span{font-size:13.5px; color:var(--text-soft);}
  .name-banner input{
    background:#fff; border:1px solid var(--line); color:var(--text);
    padding:9px 12px; border-radius:10px; font-size:13.5px; font-family:inherit; min-width:180px;
  }
  .name-banner input:focus{border-color:var(--blue); outline:none;}

  /* ---------- Progress trail ---------- */
  .trail-row{margin-top:24px;}
  .trail-stat{
    font-size:13px; font-weight:600; color:var(--blue); font-variant-numeric:tabular-nums;
    display:flex; justify-content:space-between; margin-bottom:8px;
  }
  .trail-track{height:8px; border-radius:6px; background:var(--surface-2); border:1px solid var(--line); overflow:hidden;}
  .trail-fill{height:100%; background:linear-gradient(90deg, var(--blue-deep), var(--blue)); border-radius:6px; transition:width .4s ease;}

  .doc-tracker{margin-top:18px; display:flex; align-items:center; gap:12px; flex-wrap:wrap;}
  .doc-tracker-label{font-size:12px; font-weight:600; color:var(--text-faint);}
  .doc-chips{display:flex; gap:8px; flex-wrap:wrap;}
  .doc-chip{
    border:1px solid var(--line); border-radius:20px; background:var(--surface);
    font-size:12px; font-weight:600; padding:6px 12px; cursor:pointer; font-family:inherit; transition:all .15s ease;
    box-shadow:0 1px 1px rgba(16,24,42,0.03);
  }
  .doc-chip.have{color:var(--green); border-color:#BFE0CC; background:var(--green-soft);}
  .doc-chip.missing{color:var(--red); border-color:#F0CFCB; background:#FCEEEC;}
  .doc-chip:hover{filter:brightness(.98); transform:translateY(-1px);}

  /* ---------- Layout: rail + page ---------- */
  .layout{display:grid; grid-template-columns:230px 1fr; gap:28px; margin-top:34px; align-items:start;}
  @media (max-width:780px){ .layout{grid-template-columns:1fr;} }

  .rail{display:flex; flex-direction:column; gap:4px; position:sticky; top:20px;}
  @media (max-width:780px){
    .rail{
      position:static; flex-direction:row; overflow-x:auto; gap:8px;
      padding-bottom:6px; -webkit-overflow-scrolling:touch;
    }
  }
  .rail-tab{
    background:transparent; border:none; text-align:left; cursor:pointer;
    padding:12px 14px; border-radius:13px; color:var(--text-soft);
    display:flex; flex-direction:column; gap:6px;
    transition:background .15s ease, color .15s ease;
  }
  @media (max-width:780px){ .rail-tab{min-width:150px;} }
  .rail-tab:hover{background:var(--surface); color:var(--text);}
  .rail-tab.active{background:var(--blue); color:#fff; box-shadow:0 8px 20px -10px rgba(47,111,227,0.6);}
  .rail-tab .rn{font-size:11.5px; font-weight:600; color:var(--blue); font-variant-numeric:tabular-nums;}
  .rail-tab.active .rn{color:rgba(255,255,255,.8);}
  .rail-tab .rl{font-weight:600; font-size:13.5px;}
  .rail-fillbar{height:3px; background:var(--line); border-radius:3px; overflow:hidden;}
  .rail-tab.active .rail-fillbar{background:rgba(255,255,255,.3);}
  .rail-fillbar i{display:block; height:100%; background:var(--green);}
  .rail-tab.active .rail-fillbar i{background:#fff;}

  /* ---------- Page ---------- */
  .page{
    background:transparent; color:var(--text);
    border-radius:0; padding:0;
  }
  .page-head{padding-bottom:18px; margin-bottom:10px;}
  .page-num{font-size:12px; font-weight:700; color:var(--blue); letter-spacing:.04em; text-transform:uppercase;}
  .page-title{font-family:'Fraunces',serif; font-weight:600; font-size:29px; margin:6px 0 8px; color:var(--text); letter-spacing:-0.01em;}
  .page-blurb{color:var(--text-soft); font-size:14.5px; max-width:620px; line-height:1.6;}

  .spotlight{
    background:var(--green-soft); border-radius:18px; padding:20px 22px; margin:18px 0 8px;
  }
  .spotlight-label{font-size:12px; font-weight:700; color:var(--green); margin-bottom:7px;}
  .spotlight-text{font-size:14.5px; line-height:1.6; margin:0 0 10px; color:var(--text);}
  .spotlight-list{margin:0; padding-left:18px; font-size:14px; line-height:1.65; color:var(--text);}
  .spotlight-list li{margin-bottom:6px;}

  .discord-prompt{
    background:linear-gradient(135deg, #16243C, #0E1726);
    border:1px solid var(--gold); border-radius:20px; padding:22px 24px; margin:16px 0 4px;
    box-shadow:0 18px 40px -24px rgba(14,23,38,0.6);
  }
  .discord-prompt-label{font-size:12px; font-weight:700; color:var(--gold); margin-bottom:8px; letter-spacing:.02em; text-transform:uppercase;}
  .discord-prompt-text{font-size:14.5px; line-height:1.65; margin:0; color:#EAF0FA;}
  .discord-prompt-text a{color:#E2B856; font-weight:600; text-decoration:underline;}
  .discord-prompt-contact{font-size:13.5px; margin:10px 0 0; color:#9FB1CA; font-weight:500;}

  .step{
    background:var(--surface); border:1px solid var(--line); border-radius:18px; padding:4px 20px; margin-bottom:10px;
    box-shadow:0 1px 2px rgba(16,24,42,0.03), 0 10px 24px -20px rgba(16,24,42,0.22);
    transition:box-shadow .15s ease, border-color .15s ease, opacity .15s ease;
  }
  .step:hover{border-color:#D5DEEB;}
  /* Step-by-step focus */
  .step-current{
    border-color:var(--blue); border-width:1.5px;
    box-shadow:0 2px 4px rgba(47,111,227,0.08), 0 16px 32px -20px rgba(47,111,227,0.45);
    padding:8px 22px 6px;
  }
  .step-now-label{
    font-size:11px; font-weight:700; color:var(--blue); text-transform:uppercase; letter-spacing:.04em;
    padding-top:10px;
  }
  .step-done{opacity:.62;}
  .step-done:hover{opacity:.85;}
  .step-row{display:flex; align-items:flex-start; gap:14px; padding:16px 0; cursor:pointer;}
  .chk{
    width:23px; height:23px; min-width:23px; border-radius:8px; border:2px solid var(--blue);
    margin-top:1px; display:flex; align-items:center; justify-content:center; cursor:pointer;
    background:transparent; transition:background .15s ease, border-color .15s ease;
  }
  .chk.done{background:var(--green); border-color:var(--green);}
  .chk.done::after{content:"✓"; color:#fff; font-size:13px; font-weight:700;}
  .step-main{flex:1;}
  .step-title{font-weight:600; font-size:15.5px; color:var(--text);}
  .step-title.done{color:var(--text-faint); text-decoration:line-through; text-decoration-color:var(--green);}
  .chev{color:var(--text-faint); font-size:13px; margin-top:3px; transition:transform .2s ease;}
  .chev.open{transform:rotate(90deg);}

  .step-detail{display:none; padding:0 0 18px; max-width:680px;}
  .step-detail.open{display:block;}
  .detail-block{margin-bottom:11px;}
  .detail-label{font-size:11.5px; font-weight:700; color:var(--brass-deep); margin-bottom:4px;}
  .detail-text{font-size:14px; line-height:1.55; color:var(--text-on-paper);}
  .how-list{margin:0; padding-left:18px; font-size:14px; line-height:1.6; color:var(--text-on-paper);}
  .how-list li{margin-bottom:3px;}
  textarea.note-field{
    width:100%; margin-top:8px; border:1px solid var(--paper-dim); background:#FAFBFD;
    border-radius:12px; padding:9px 12px; font-family:inherit; font-size:13.5px; resize:vertical; min-height:46px;
  }
  .note-hint{font-size:11px; color:var(--text-soft-on-paper); margin-top:4px;}

  .page-footer{margin-top:18px; padding-top:18px; border-top:1px solid var(--line); display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:10px;}
  .footer-nav-btn{
    background:var(--ink); color:#fff; border:none; padding:11px 18px; border-radius:12px;
    font-size:13.5px; font-weight:600; cursor:pointer; transition:background .15s ease;
  }
  .footer-nav-btn:hover{background:var(--ink-soft);}
  .reset-link{background:none; border:none; color:var(--red); font-size:12.5px; cursor:pointer; text-decoration:underline;}

  .loading{display:flex; align-items:center; justify-content:center; min-height:60vh; color:var(--text-soft); font-size:13.5px;}

  /* ---------- Branded loading screen ---------- */
  .apex-loader{
    position:fixed; inset:0; z-index:9999;
    background:radial-gradient(circle at 50% 42%, #16233A 0%, #0E1726 60%, #080E18 100%);
    display:flex; align-items:center; justify-content:center;
    opacity:1; transition:opacity .55s ease;
  }
  .apex-loader.fade-out{opacity:0;}
  .apex-loader.hidden{display:none;}
  .apex-loader-inner{display:flex; flex-direction:column; align-items:center; gap:26px;}
  .apex-loader-logo{
    width:min(260px, 62vw); height:auto; display:block;
    animation:apexLogoIn .9s cubic-bezier(.2,.7,.2,1) both, apexLogoPulse 2.4s ease-in-out .9s infinite;
  }
  .apex-loader-bar{
    width:150px; height:3px; border-radius:3px; background:rgba(255,255,255,.12); overflow:hidden;
  }
  .apex-loader-bar span{
    display:block; height:100%; width:40%; border-radius:3px;
    background:linear-gradient(90deg, transparent, var(--gold), transparent);
    animation:apexBar 1.3s ease-in-out infinite;
  }
  @keyframes apexLogoIn{
    0%{opacity:0; transform:scale(.86) translateY(8px);}
    100%{opacity:1; transform:scale(1) translateY(0);}
  }
  @keyframes apexLogoPulse{
    0%,100%{transform:scale(1);}
    50%{transform:scale(1.035);}
  }
  @keyframes apexBar{
    0%{transform:translateX(-160%);}
    100%{transform:translateX(420%);}
  }
  @media (prefers-reduced-motion: reduce){
    .apex-loader-logo{animation:apexLogoIn .4s ease both;}
    .apex-loader-bar span{animation:none; width:100%;}
  }

  /* App fades in once loaded */
  #app{opacity:0; transition:opacity .5s ease;}
  #app.ready{opacity:1;}

  /* Soft fade-up for main content areas on render */
  .layout, .script-layout{animation:contentIn .4s ease both;}
  @keyframes contentIn{
    0%{opacity:0; transform:translateY(6px);}
    100%{opacity:1; transform:translateY(0);}
  }
  @media (prefers-reduced-motion: reduce){
    .layout, .script-layout{animation:none;}
    html{scroll-behavior:auto;}
  }

  /* Training Library */
  .script-layout{display:grid; grid-template-columns:210px 1fr; gap:24px;}
  @media (max-width:680px){ .script-layout{grid-template-columns:1fr;} }
  .script-list{display:flex; flex-direction:column; gap:6px;}
  .script-list-btn{
    text-align:left; background:var(--surface); border:1px solid var(--line); border-radius:14px;
    padding:12px 14px; font-size:13.5px; font-weight:600; color:var(--text-soft); cursor:pointer; transition:all .15s ease;
  }
  .script-list-btn:hover{border-color:#D5DEEB; color:var(--text);}
  .script-list-btn.active{background:var(--ink); color:#fff; border-color:var(--ink);}
  .script-detail-head{display:flex; justify-content:space-between; align-items:flex-start; gap:12px; flex-wrap:wrap; margin-bottom:8px;}
  .script-title{font-family:'Fraunces',serif; font-weight:600; font-size:23px; margin:0 0 5px; color:var(--text);}
  .script-subtitle{color:var(--text-soft); font-size:13.5px; margin:0; max-width:480px; line-height:1.55;}
  .script-stage{display:flex; gap:14px; padding:16px 18px; background:var(--surface); border:1px solid var(--line); border-radius:16px; margin-bottom:8px; box-shadow:0 1px 2px rgba(16,24,42,0.03);}
  .script-stage-num{font-size:13px; font-weight:700; color:var(--blue); min-width:22px; font-variant-numeric:tabular-nums;}
  .script-stage-title{font-weight:600; font-size:14.5px; margin-bottom:7px;}
  .script-stage-lines{margin:0; padding-left:18px; font-size:14px; line-height:1.6; color:var(--text);}
  .script-stage-lines li{margin-bottom:5px;}

  .objection-filterbar{display:flex; align-items:center; gap:8px; flex-wrap:wrap; margin-bottom:16px;}
  .filter-chip{
    background:#fff; border:1px solid var(--paper-dim); border-radius:20px; padding:7px 14px;
    font-size:12.5px; font-weight:600; color:var(--text-soft-on-paper); cursor:pointer; transition:all .15s ease;
  }
  .filter-chip.active{background:var(--brass); border-color:var(--brass); color:#fff;}
  .objection-count{margin-left:auto; font-size:12px; font-weight:500; color:var(--text-soft-on-paper); font-variant-numeric:tabular-nums;}
  .objection-grid{display:grid; grid-template-columns:repeat(2,1fr); gap:12px;}
  @media (max-width:680px){ .objection-grid{grid-template-columns:1fr;} }
  .objection-card{
    border:1px solid var(--line); border-radius:18px; padding:16px 18px; cursor:pointer; background:var(--surface);
    box-shadow:0 1px 2px rgba(16,24,42,0.03), 0 10px 24px -20px rgba(16,24,42,0.22);
    transition:box-shadow .15s ease, border-color .15s ease;
  }
  .objection-card:hover{border-color:#D5DEEB;}
  .objection-card.open{border-color:var(--blue); box-shadow:0 0 0 1px var(--blue), 0 10px 24px -18px rgba(47,111,227,0.4); grid-column:1/-1;}
  .objection-tag{font-size:11px; font-weight:700; color:var(--blue); margin-bottom:7px; text-transform:uppercase; letter-spacing:.02em;}
  .objection-text{font-weight:600; font-size:14.5px; color:var(--text);}
  .objection-hint{font-size:12px; color:var(--text-faint); margin-top:8px;}
  .objection-rebuttal{font-size:13.5px; line-height:1.6; margin-top:10px; color:var(--text);}
  .objection-tip{font-size:13px; line-height:1.55; margin-top:8px; color:var(--text-soft);}

  .quiz-grid{display:grid; grid-template-columns:repeat(3,1fr); gap:14px;}
  @media (max-width:780px){ .quiz-grid{grid-template-columns:1fr;} }
  .quiz-card{
    border:1px solid var(--line); border-radius:20px; padding:22px; display:flex; flex-direction:column; gap:8px; background:var(--surface);
    box-shadow:0 1px 2px rgba(16,24,42,0.03), 0 10px 24px -20px rgba(16,24,42,0.22);
  }
  .quiz-card-title{font-family:'Fraunces',serif; font-weight:600; font-size:18px; color:var(--text);}
  .quiz-card-meta{font-size:12.5px; color:var(--text-soft);}
  .quiz-card-result{font-size:12.5px; font-weight:600; padding:4px 0;}
  .quiz-card-result.pass{color:var(--green);}
  .quiz-card-result.fail{color:var(--red);}
  .quiz-card-result.none{color:var(--text-faint);}
  .quiz-question{padding:18px 20px; background:var(--surface); border:1px solid var(--line); border-radius:16px; margin-bottom:8px;}
  .quiz-question-text{font-weight:600; font-size:14.5px; margin-bottom:11px; color:var(--text);}
  .quiz-options{display:flex; flex-direction:column; gap:8px;}
  .quiz-option{
    text-align:left; background:var(--surface-2); border:1px solid var(--line); border-radius:12px;
    padding:11px 14px; font-size:13.5px; cursor:pointer; font-family:inherit; transition:all .15s ease; color:var(--text);
  }
  .quiz-option:hover{border-color:#C8D4E6;}
  .quiz-option.selected{border-color:var(--blue); background:var(--blue-soft);}
  .quiz-option.reviewed{cursor:default;}
  .quiz-option.correct{border-color:var(--green); background:var(--green-soft); font-weight:600;}
  .quiz-option.incorrect{border-color:var(--red); background:#FCEEEC;}
