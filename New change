    });

    document.querySelectorAll('[data-quizretry]').forEach(btn=>{
      btn.onclick = ()=>{ activeQuizId = btn.getAttribute('data-quizretry'); quizAnswers = {}; quizSubmitted = false; render(); };
    });

    document.querySelectorAll('[data-quizanswer]').forEach(btn=>{
      btn.onclick = ()=>{
