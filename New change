  // Escape HTML, then turn any bare http(s) URL into a clickable link.
  // Safe because escaping happens first; only the matched URL substring becomes an anchor.
  function linkify(str){
    const escaped = escapeHtml(str);
    return escaped.replace(/(https?:\/\/[^\s<]+)/g, function(url){
      // strip a trailing period/paren that's likely punctuation, not part of the URL
      let trail = '';
      const m = url.match(/[).,]+$/);
      if(m){ trail = url.slice(url.length - m[0].length); url = url.slice(0, url.length - m[0].length); }
      return `<a href="${url}" target="_blank" rel="noopener">${url}</a>${trail}`;
    });
  }

